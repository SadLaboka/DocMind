#Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_RELOAD=true
#Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_HOST=localhost
DB_PORT=5432
#JWT-auth
JWT_TIMEDELTA=15
JWT_REFRESH_TIMEDELTA=7
JWT_ALGORITHM=RS256
#Logs
LOGS_DEV=False
LOGS_LEVEL=30
#RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASSWORD=guest
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=15672
RABBITMQ_PANEL_PORT=15672
RABBITMQ_DOCUMENT_EXCHANGE_NAME=documents
RABBITMQ_EXTRACTED_ROUTING_KEY=documents.text.extracted
#Mongo
MONGO_USERNAME=root
MONGO_PASSWORD=example
MONGO_PORT=27017
MONGO_HOST=127.0.0.1
MONGO_NAME=DocMind
#Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_COMMANDER_PORT=8081
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
#Cache
CACHE_PROMPT_TTL=3600
CACHE_USER_STATUS_TTL=3600
#Rate limiting
RATE_LIMIT_GLOBAL_LIMIT=60
RATE_LIMIT_GLOBAL_WINDOW=60
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_LIMIT=3
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_DOCUMENTS_POST_LIMIT=10
RATE_LIMIT_DOCUMENTS_POST_WINDOW=60
RATE_LIMIT_DOCUMENTS_GET_LIMIT=20
RATE_LIMIT_DOCUMENTS_GET_WINDOW=60
#Initial Prompt
PROMPT_INITIAL_VERSION=v1.0.0
#LLM
LLM_DEFAULT_PROVIDER=deepseek
#Providers
#Gemini
GEMINI_API_KEY=api_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT=60
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.2
#DeepSeek
DEEPSEEK_API_KEY=api_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.2
